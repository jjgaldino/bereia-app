# ============================================
# BEREIA — Variáveis de Ambiente
# ============================================

# Chave da API OpenAI (obrigatória)
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# [FUTURO] Chave da API Anthropic (opcional, para modo profundo)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Chave do dashboard admin (opcional, padrão: bereia2025)
# Acesse em: bereiaestudos.com.br/admin
ADMIN_KEY=bereia2025

# Upstash Redis — para persistência do dashboard analytics
# Crie grátis em: https://console.upstash.com
# Clique em "Create Database" → copie REST URL e REST Token
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxx
